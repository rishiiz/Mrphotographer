{
  "name": "mrphotographer-backend",
  "version": "1.0.0",
  "description": "Backend API for Mr.Photographer photographer booking website",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node -e \"import('./database.js').then(m => m.initDb().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); }))\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
